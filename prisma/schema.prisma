generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EnvelopeStatus {
  DISPONIBILE
  RISERVATA
  VENDUTA
}

enum JerseyStatus {
  ATTIVA
  CHIUSA
}

model LotteryEnvelope {
  id         Int                     @id @default(autoincrement())
  number     Int                     @unique
  status     EnvelopeStatus          @default(DISPONIBILE)
  reservedBy String?
  updatedAt  DateTime                @updatedAt
  history    LotteryEnvelopeHistory[]
}

model LotteryEnvelopeHistory {
  id             Int            @id @default(autoincrement())
  envelopeId     Int
  previousStatus EnvelopeStatus
  newStatus      EnvelopeStatus
  reservedBy     String?
  createdAt      DateTime       @default(now())

  envelope LotteryEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
}

model Jersey {
  id            Int          @id @default(autoincrement())
  playerNumber  Int
  playerSurname String
  startingPrice Decimal      @db.Decimal(10, 2)
  currentPrice  Decimal      @db.Decimal(10, 2)
  status        JerseyStatus @default(ATTIVA)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bids          Bid[]
}

model Bid {
  id         Int      @id @default(autoincrement())
  jerseyId   Int
  bidderName String
  amount     Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  jersey Jersey @relation(fields: [jerseyId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id                             Int      @id @default(1)
  homepageAuctionRotationSeconds Int      @default(30)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}
